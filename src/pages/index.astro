---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  shouldIncludePresentation,
  sortPresentationsByDateDesc,
} from "../lib/presentations";
import homeStyles from "../styles/home.module.css";
import pageStyles from "../styles/page.module.css";

const title = "Meeting Presentation Reports";
const description =
  "A site for sharing meeting content with colleagues who want to review the key points after each talk.";
const dateFormatter = new Intl.DateTimeFormat("en", { dateStyle: "medium" });
const presentations = sortPresentationsByDateDesc(
  await getCollection("presentations", shouldIncludePresentation),
);
---

<BaseLayout title={title} description={description}>
  <main class={pageStyles.shell}>
    <header class={pageStyles.header}>
      <h1 class={pageStyles.title}>{title}</h1>
      <p class={pageStyles.description}>{description}</p>
    </header>

    {
      presentations.length > 0 ? (
        <ul class={homeStyles.presentationList}>
          {presentations.map((presentation) => (
            <li>
              <a
                class={homeStyles.presentationCard}
                href={`/presentations/${presentation.id}/`}
              >
                <h2 class={homeStyles.presentationCardTitle}>
                  {presentation.data.title}
                </h2>
                <div class={pageStyles.meta}>
                  <time datetime={presentation.data.date.toISOString()}>
                    {dateFormatter.format(presentation.data.date)}
                  </time>
                  {presentation.data.draft ? (
                    <span class={pageStyles.draftBadge}>Draft</span>
                  ) : null}
                </div>
                {presentation.data.description ? (
                  <p class={homeStyles.presentationCardDescription}>
                    {presentation.data.description}
                  </p>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class={pageStyles.emptyState}>
          No published presentations are available yet.
        </p>
      )
    }
  </main>
</BaseLayout>
